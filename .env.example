# Claude Memory Machine — Environment Variables
# Copy this file to ~/.env or your preferred env location
# Only needed for optional integrations (Mem0, Claude API agents)

# ============================================================================
# Mem0 Cloud (Optional — for ground truth episodic memory)
# Get your key at: https://app.mem0.ai/
# ============================================================================
# MEM0_API_KEY=paste_your_key_here
MEM0_USER_ID=your-username-claude-memory

# ============================================================================
# Anthropic API (Optional — for Claude-powered agent analysis)
# Get your key at: https://console.anthropic.com/
# Without this, agents use heuristic analysis (still works, just less rich)
# ============================================================================
# ANTHROPIC_API_KEY=paste_your_key_here
